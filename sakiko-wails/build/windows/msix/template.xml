<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="sakiko.exe"
        Arguments=""
        InstallLocation="C:\Program Files\Kanda Akihito\sakiko">
    </Installer>
    <PackageInformation
        PackageName="sakiko"
        PackageDisplayName="sakiko"
        PublisherName="CN=Kanda Akihito"
        PublisherDisplayName="Kanda Akihito"
        Version="0.2.1.0"
        PackageDescription="Desktop proxy benchmark and speed test tool">
        <Capabilities>
            <Capability Name="runFullTrust" />
            
        </Capabilities>
        <Applications>
            <Application
                Id="io.github.kanda-akihito-kun.sakiko"
                Description="Desktop proxy benchmark and speed test tool"
                DisplayName="sakiko"
                ExecutableName="sakiko.exe"
                EntryPoint="Windows.FullTrustApplication">
                
            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>sakiko</DisplayName>
            <PublisherDisplayName>Kanda Akihito</PublisherDisplayName>
            <Description>Desktop proxy benchmark and speed test tool</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="sakiko.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
